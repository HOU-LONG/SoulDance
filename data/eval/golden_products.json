{
  "_meta": {
    "description": "Phase 3 答辩级评测金标。基于 ecommerce_agent_dataset/ 100 个商品自动推断后人工 review。",
    "fields": {
      "query": "用户原始 query（仅作可读说明，runner 不使用）",
      "ideal_top": "最理想的 top-K product_id（有序，靠前的 NDCG 权重更高）",
      "acceptable": "Recall@K 计算时认可的全集（无序，覆盖 ideal_top）",
      "forbidden": "明确不该出现的 product_id（违反硬约束的商品）"
    },
    "selection_basis": {
      "ideal_top": "根据 query 的核心约束（类目+价格+品牌+成分）筛出最匹配的；同条件下取性价比/评分高的优先",
      "acceptable": "包含 ideal_top + 同类目下次优商品；用于宽松 Recall（任一命中即认可）",
      "forbidden": "完全违反硬约束（如查防晒返回手机、要求不含酒精却推含酒精商品）"
    }
  },

