{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LongSessionTurnTrace",
  "description": "长会话评测单轮 trace 记录（spec §9.1）",
  "type": "object",
  "required": [
    "condition",
    "session_id",
    "turn_index",
    "phase",
    "turn_type",
    "query",
    "expected",
    "pipeline",
    "tool_calls",
    "branch_flags",
    "prompt_tokens",
    "completion_tokens",
    "first_chunk_ms",
    "total_ms",
    "context_payload_bytes",
    "context_payload_tokens",
    "context_events_count",
    "focus_history_len",
    "hard_constraints",
    "would_hit_b1",
    "effective_hit_b1",
    "would_hit_b2",
    "effective_hit_b2",
    "cache_stats_at_turn",
    "rule_score",
    "answer_text",
    "retrieved_top_k",
    "script_version_hash",
    "product_list_hash",
    "condition_config_hash"
  ],
  "properties": {
    "condition": {
      "type": "string",
      "enum": ["C0", "C1", "C2", "C3", "C4"]
    },
    "session_id": {
      "type": "string"
    },
    "turn_index": {
      "type": "integer",
      "minimum": 0
    },
    "phase": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"]
    },
    "turn_type": {
      "type": "string"
    },
    "adversarial_subtype": {
      "anyOf": [{"type": "string"}, {"type": "null"}]
    },
    "query": {
      "type": "string"
    },
    "expected": {
      "type": "object"
    },
    "pipeline": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tool_calls": {
      "type": "array",
      "items": {"type": "object"}
    },
    "branch_flags": {
      "type": "object"
    },
    "prompt_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "completion_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "first_chunk_ms": {
      "type": "integer",
      "minimum": 0
    },
    "total_ms": {
      "type": "integer",
      "minimum": 0
    },
    "context_payload_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "context_payload_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "context_events_count": {
      "type": "integer",
      "minimum": 0
    },
    "focus_history_len": {
      "type": "integer",
      "minimum": 0
    },
    "focus_product_id": {
      "anyOf": [{"type": "string"}, {"type": "null"}]
    },
    "hard_constraints": {
      "type": "object"
    },
    "state_drift": {
      "anyOf": [{"type": "object"}, {"type": "null"}]
    },
    "degradation": {
      "anyOf": [{"type": "object"}, {"type": "null"}]
    },
    "would_hit_b1": {
      "type": "boolean"
    },
    "effective_hit_b1": {
      "type": "boolean"
    },
    "would_hit_b2": {
      "type": "boolean"
    },
    "effective_hit_b2": {
      "type": "boolean"
    },
    "cache_stats_at_turn": {
      "type": "object"
    },
    "rule_score": {
      "type": "object"
    },
    "judge_score": {
      "anyOf": [
        {
          "type": "object",
          "required": ["raw", "mean", "disagreement", "call_count"],
          "properties": {
            "raw": {"type": "array", "items": {"type": "object"}},
            "mean": {"type": "number"},
            "disagreement": {"type": "number"},
            "call_count": {"type": "integer", "minimum": 1}
          }
        },
        {"type": "null"}
      ]
    },
    "answer_text": {
      "type": "string"
    },
    "retrieved_top_k": {
      "type": "array",
      "items": {"type": "string"}
    },
    "script_version_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "product_list_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "condition_config_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
