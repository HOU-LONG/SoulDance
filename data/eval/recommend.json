[
  {
    "id": "recommend_basic_sunscreen",
    "session_id": "eval_recommend_basic_sunscreen",
    "tags": ["recommend", "explicit"],
    "golden_id": "recommend_sunscreen_basic",
    "message": "推荐一款防晒霜",
    "expect": {
      "min_product_items": 1,
      "event_types": ["ack", "products_start", "product_item", "done"],
      "expect_product_ids_subset_of": ["p_beauty_006", "p_beauty_010", "p_beauty_023"]
    }
  },
  {
    "id": "recommend_ambiguous_phone",
    "session_id": "eval_recommend_ambiguous_phone",
    "tags": ["recommend", "ambiguous"],
    "message": "推荐一款手机",
    "expect": {
      "event_types": ["ack"],
      "expect_clarification": true
    }
  },
  {
    "id": "recommend_phone_brand_include",
    "session_id": "eval_recommend_phone_brand_include",
    "tags": ["recommend", "brand_include"],
    "golden_id": "recommend_phone_huawei",
    "message": "推荐一款华为手机",
    "expect": {
      "min_product_items": 1,
      "expected_brands": ["华为"],
      "forbidden_brands": ["Apple 苹果", "小米", "OPPO", "vivo"]
    }
  },
  {
    "id": "recommend_phone_brand_exclude_apple",
    "session_id": "eval_recommend_phone_brand_exclude_apple",
    "tags": ["recommend", "brand_exclude"],
    "golden_id": "recommend_phone_no_apple",
    "message": "推荐手机，不要苹果，预算 6000",
    "expect": {
      "min_product_items": 1,
      "price_max": 6000,
      "forbidden_brands": ["Apple 苹果", "苹果"]
    }
  },
  {
    "id": "recommend_sunscreen_no_alcohol",
    "session_id": "eval_recommend_sunscreen_no_alcohol",
    "tags": ["recommend", "exclude_term"],
    "golden_id": "recommend_sunscreen_no_alcohol",
    "message": "推荐一款防晒霜，不要含酒精",
    "expect": {
      "min_product_items": 1,
      "forbid_terms": ["酒精", "alcohol"],
      "forbidden_product_ids": ["p_beauty_010", "p_beauty_023"],
      "expected_product_ids": ["p_beauty_006"]
    }
  },
  {
    "id": "recommend_drink_no_carbonated",
