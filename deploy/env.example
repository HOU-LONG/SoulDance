# Stage 0/01 host-runtime defaults for mix_A100.
# Copy selected values into server/.env or export them in the shell.
# Do not commit real provider keys.

# Seed/runtime selection. Used by server/scripts/setup_backend_env.sh.
SEED_PYTHON=/home/huadabioa/houlong/SoulDance/env/venv_vllm_cu128/bin/python
BACKEND_VENV=/home/huadabioa/houlong/SoulDance/env/venv_shopguide_backend

# Backend bind. Use 8000 for the live backend; use 18083 for smoke checks.
HOST=0.0.0.0
PORT=8000
SERVER_BASE_URL=

# LLM. Leave keys empty for fake-LLM smoke checks.
LLM_PROVIDER=doubao
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/
ARK_MODEL=ep-20260514111645-lmgt2
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_FAST_MODEL=
LLM_REASONING_EFFORT=

# Retrieval. Smoke checks can set USE_EMBEDDING=0; live runtime can use CUDA embeddings.
EMBEDDING_MODEL_DIR=model/bge-small-zh-v1.5
EMBEDDING_DEVICE=cuda:0
USE_EMBEDDING=1

# Runtime persistence.
SHOPGUIDE_SESSION_DIR=data/sessions
SHOPGUIDE_CART_PATH=data/carts.json
SHOPGUIDE_MEMORY_CACHE_PATH=
SHOPGUIDE_FEEDBACK_PATH=
SHOPGUIDE_USER_PROFILE_DIR=
SHOPGUIDE_SESSION_TTL_DAYS=7

# PostgreSQL + pgvector
SHOPGUIDE_DATABASE_URL=postgresql+psycopg://shopguide:shopguide@localhost:5432/shopguide
SHOPGUIDE_EMBEDDING_DIMENSION=384

# TTS.
TTS_ENABLED=true
TTS_PROVIDER=doubao_chunked_v3
TTS_BASE_URL=http://127.0.0.1:18880
TTS_API_KEY=EMPTY
TTS_MODEL=qwen3-tts
TTS_RESPONSE_FORMAT=wav
TTS_TASK_TYPE=VoiceDesign
TTS_DEFAULT_VOICE=calm_female
TTS_DEFAULT_INSTRUCTIONS=A calm, clear female narrator voice.
TTS_TIMEOUT_SECONDS=30
TTS_STREAM=false
TTS_MAX_TEXT_LENGTH=500
TTS_CHUNK_DURATION_MS=200
DOUBAO_VOICE_API_KEY=
DOUBAO_TTS_URL=https://openspeech.bytedance.com/api/v3/tts/unidirectional
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_MODEL=seed-tts-2.0-standard
DOUBAO_TTS_SPEAKER=zh_female_wenroushunv_uranus_bigtts
DOUBAO_TTS_FORMAT=pcm
DOUBAO_TTS_SAMPLE_RATE=24000
DOUBAO_TTS_SPEECH_RATE=0
DOUBAO_TTS_LOUDNESS_RATE=0

# STT.
STT_ENABLED=true
STT_PROVIDER=doubao_ws
STT_BASE_URL=http://127.0.0.1:18090
STT_API_KEY=
STT_MODEL=paraformer-zh
STT_AUDIO_FORMAT=wav
STT_SAMPLE_RATE=16000
STT_TIMEOUT_SECONDS=30
STT_MAX_AUDIO_SIZE_MB=10
DOUBAO_ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_ASR_UID=souldance-android
DOUBAO_ASR_AUDIO_FORMAT=pcm
DOUBAO_ASR_LANGUAGE=zh-CN
DOUBAO_ASR_CHUNK_MS=200
DOUBAO_ASR_INTER_CHUNK_DELAY_MS=0
DOUBAO_ASR_ENABLE_ITN=true
DOUBAO_ASR_ENABLE_PUNC=true
DOUBAO_ASR_RESULT_TYPE=full
